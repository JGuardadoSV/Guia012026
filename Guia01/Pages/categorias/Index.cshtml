@page
@model Guia01.Pages.categorias.IndexModel

@{
    ViewData["Title"] = "Index";
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Categoria[0].Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Categoria[0].Descripcion)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-dark fw-bold">Gestión de Categorías</h2>
                <a asp-page="./Create" class="btn btn-primary shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Nueva Categoría
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">@Html.DisplayNameFor(model => model.Categoria[0].Nombre)</th>
                                <th>@Html.DisplayNameFor(model => model.Categoria[0].Descripcion)</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @foreach (var item in Model.Categoria)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">
                                        @Html.DisplayFor(modelItem => item.Nombre)
                                    </td>
                                    <td class="text-secondary">
                                        @Html.DisplayFor(modelItem => item.Descripcion)
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Editar">
                                                <i class="bi bi-pencil"></i> <span class="d-none d-md-inline">Editar</span>
                                            </a>
                                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Detalles">
                                                <i class="bi bi-eye"></i> <span class="d-none d-md-inline">Detalles</span>
                                            </a>
                                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i> <span class="d-none d-md-inline">Eliminar</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </tbody>
</table>
