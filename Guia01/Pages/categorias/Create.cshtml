@page
@model Guia01.Pages.categorias.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Registro de nueva Categoria</h1>
        
   
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Categoria.Nombre" class="control-label"></label>
                <input asp-for="Categoria.Nombre" class="form-control" aria-required="true"/>
                <span asp-validation-for="Categoria.Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Categoria.Descripcion" class="control-label"></label>
                <input asp-for="Categoria.Descripcion" class="form-control" />
                <span asp-validation-for="Categoria.Descripcion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Registrar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Volver a la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
